# Exemplo de variáveis de ambiente. Copie para `.env` e preencha.
#
# SEGURANÇA: nunca versione segredos reais. As chaves abaixo prefixadas com
# VITE_ e a publishable/anon key são PÚBLICAS (vão para o bundle do cliente).
# A SERVICE_ROLE_KEY e os demais segredos abaixo são PRIVADOS — só no ambiente
# do servidor (Supabase/Lovable secrets), JAMAIS no repositório.

# --- Públicas (cliente) ---
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# --- Servidor (Supabase) ---
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
# PRIVADO — bypassa RLS. Só no ambiente, nunca commitado.
SUPABASE_SERVICE_ROLE_KEY=

# --- API pública para integrações ---
# Clientes, hashes SHA-256, escopos e restrições ficam em api_clientes e
# api_cliente_escopos. O segredo em texto puro é entregue uma única vez ao
# cliente e nunca é salvo no banco ou neste arquivo.
# Limite de requisições/min por chave/IP (default 60).
PUBLIC_API_RATE_LIMIT=
# Salt privado usado para pseudonimizar IPs na auditoria. Se vazio, o IP não é
# persistido.
API_AUDIT_IP_SALT=

# --- Credenciais globais legadas (remoção obrigatória após o corte) ---
READ_API_KEY=
MCP_WRITE_API_KEY=
# As chaves acima só funcionam quando todas as configurações abaixo são
# válidas. STARTED_AT/UNTIL devem ser ISO-8601 e delimitar no máximo 7 dias.
PUBLIC_API_LEGACY_ENABLED=false
PUBLIC_API_LEGACY_STARTED_AT=
PUBLIC_API_LEGACY_UNTIL=
# Opt-in adicional para READ_API_KEY realizar escrita durante a mesma janela.
PUBLIC_WRITE_ALLOW_READ_KEY=false

# --- Webhook da landing page ---
# O formulário envia `Idempotency-Key` no header e `turnstile_token` no JSON.
# Nenhum segredo desta seção pertence ao JavaScript da landing.
# Origens exatas, separadas por vírgula. Wildcard não é aceito.
LANDING_ALLOWED_ORIGINS=https://www.seumetroquadrado.com.br
# PRIVADO, mínimo 32 caracteres aleatórios. Usado para HMAC de IP e
# Idempotency-Key; IP e chave crus nunca são persistidos.
LANDING_HASH_SECRET=
# PRIVADO — secret key do Cloudflare Turnstile, validada somente no servidor.
# A site key pública pertence à configuração da landing externa.
TURNSTILE_SECRET_KEY=
# Máx. de posts por fingerprint/IP na janela distribuída (default 12/60 s).
LANDING_RATE_LIMIT=
LANDING_RATE_WINDOW_SECONDS=

# --- Push (web-push) ---
# Segredo dedicado para autenticar /api/public/hooks/push-dispatch.
# Obrigatório: sem ele o endpoint falha fechado; anon/publishable não servem.
PUSH_DISPATCH_SECRET=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@seumetroquadrado.com.br

# --- IA (match) ---
LOVABLE_API_KEY=
# Limite de buscas de IA/min por usuário (default 20).
MATCH_IA_RATE_LIMIT=

# --- Vitrine pública ---
# Hosts HTTPS exatos (sem protocolo), separados por vírgula. Book/tabela em
# qualquer outro host — ou com query/hash sensível — são removidos da resposta.
# Vazio é fail-closed: a shortlist funciona, mas não publica links externos.
VITRINE_PUBLIC_ALLOWED_HOSTS=

# --- Lead intake (edge function) ---
LEAD_INTAKE_SECRET=
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
APP_BASE_URL=
