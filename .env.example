# Exemplo de variáveis de ambiente. Copie para `.env` e preencha.
#
# SEGURANÇA: nunca versione segredos reais. As chaves abaixo prefixadas com
# VITE_ e a publishable/anon key são PÚBLICAS (vão para o bundle do cliente).
# A SERVICE_ROLE_KEY e os demais segredos abaixo são PRIVADOS — só no ambiente
# do servidor (Supabase/Lovable secrets), JAMAIS no repositório.

# --- Públicas (cliente) ---
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# --- Servidor (Supabase) ---
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
# PRIVADO — bypassa RLS. Só no ambiente, nunca commitado.
SUPABASE_SERVICE_ROLE_KEY=

# --- API pública de leitura ---
READ_API_KEY=
# Limite de requisições/min por chave/IP (default 60).
PUBLIC_API_RATE_LIMIT=

# --- API pública de escrita (leads/:id, /corretor, /perda, /eventos) ---
# Chave dedicada de ESCRITA. É o destino final de auth desses endpoints.
MCP_WRITE_API_KEY=
# Transição: enquanto != "false", os endpoints de escrita ainda aceitam a
# READ_API_KEY (modo legado, auditado em api_escrita_log). Quando todos os
# clientes (n8n/MCP) estiverem usando MCP_WRITE_API_KEY, defina como "false"
# para cortar a chave de leitura sem novo deploy.
PUBLIC_WRITE_ALLOW_READ_KEY=

# --- Webhook da landing page ---
# Opcional: quando setado, o webhook exige o header x-landing-secret.
# Deixe vazio enquanto o form posta direto do browser (protegido por rate
# limit + honeypot).
LANDING_WEBHOOK_SECRET=
# Máx. de posts por IP por minuto no webhook da landing (default 12).
LANDING_RATE_LIMIT=

# --- Push (web-push) ---
# Segredo dedicado para autenticar /api/public/hooks/push-dispatch.
# Enquanto vazio, cai para a anon key (legado). Defina para endurecer.
PUSH_DISPATCH_SECRET=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@seumetroquadrado.com.br

# --- IA (match) ---
LOVABLE_API_KEY=
# Limite de buscas de IA/min por usuário (default 20).
MATCH_IA_RATE_LIMIT=

# --- Lead intake (edge function) ---
LEAD_INTAKE_SECRET=
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
APP_BASE_URL=
